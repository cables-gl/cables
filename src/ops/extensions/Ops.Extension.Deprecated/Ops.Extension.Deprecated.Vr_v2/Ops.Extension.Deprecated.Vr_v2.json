    "changelog": [
        {
            "message": "created op",
            "author": "pandur",
            "date": 1655205733018,
            "type": "new"
        },
        {
            "message": "Toggle between immersion AR and VR, choose AR to have a pass through mode on supporting headsets, like quest 3",
            "type": "feature",
            "author": "pandur",
            "date": 1769530114260
        },
        {
            "message": "Better positioning of VR camera, much more exact overlaying when rendering nearby objects",
            "type": "improvement",
            "author": "pandur",
            "date": 1769592362782
        },
        {
            "message": "Now automatically uses local-floor reference space if available, 0,0,0 is then always attached to your real world floor",
            "type": "feature",
            "author": "pandur",
            "date": 1769596342728
        },
        {
